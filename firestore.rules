rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /leads/{leadId} {
      allow read: if false; // Only admin (server) can read for now
      allow create: if true; // Technically redundant since server does it, but good to have
    }

    match /chats/{chatId} {
      allow read: if false;
      allow write: if false;
      
      match /messages/{messageId} {
        allow read, write: if false;
      }
    }
  }
}
